            <str name="mm">2</str>
            <str name="pf">label_txt_en^10 description_txt_en^5 query_txt_en^5 title_txt_en^3 docDescription_txt_en^2
            </str>
            <str name="qf">label_txt_en^20 description_txt_en^5 query_txt_en^5 title_txt_en^3 docDescription_txt_en^2
                _text_^0.01
            </str>
            <str name="fq">type_s:Topic</str>

            <str name="hl">true</str>
            <str name="hl.snippets">5</str>
            <str name="hl.fl">label_txt_en description_txt_en query_txt_en title_txt_en docDescription_txt_en</str>
